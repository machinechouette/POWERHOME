<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2EE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="52dp"
        android:paddingBottom="40dp">

        <!-- Bouton retour -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_input_field"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Retour"
            android:padding="8dp"
            app:tint="#2D3A2E" />

        <!-- Avatar / Logo -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:src="@drawable/ic_lotus"
            android:contentDescription="Avatar" />

        <!-- Pseudo actuel affiché -->
        <TextView
            android:id="@+id/tv_current_pseudo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:textColor="#2D3A2E"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="Résident" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="Modifier votre profil"
            android:textColor="#5A6B58"
            android:textSize="13sp" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp"
            android:background="#DDE5DA" />

        <!-- Pseudo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Pseudo"
                android:tint="#6B8068" />

            <EditText
                android:id="@+id/et_pseudo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Pseudo"
                android:textColorHint="#8FA68C"
                android:textColor="#2D3A2E"
                android:textSize="15sp"
                android:inputType="textPersonName"
                android:singleLine="true" />
        </LinearLayout>

        <!-- E-mail -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_email"
                android:contentDescription="Email"
                android:tint="#6B8068" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="E-mail"
                android:textColorHint="#8FA68C"
                android:textColor="#2D3A2E"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Nouveau mot de passe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="Mot de passe"
                android:tint="#6B8068" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Nouveau mot de passe (optionnel)"
                android:textColorHint="#8FA68C"
                android:textColor="#2D3A2E"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Confirmation mot de passe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="Confirmer"
                android:tint="#6B8068" />

            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Confirmer le mot de passe"
                android:textColorHint="#8FA68C"
                android:textColor="#2D3A2E"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Bouton Enregistrer -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_primary"
            android:text="Enregistrer les modifications"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
